    {
      "parameters": {
        "jsCode": "const payload = $input.first().json;\nconst contact = payload.hubspot.contact;\nconst props = payload.hubspot.properties;\n\nconst properties = {\n  firstname: contact.firstName || '',\n  lastname: contact.lastName || '',\n  hiweb_booking_id: props.bookingId,\n  hiweb_service: props.serviceLabel,\n  hiweb_schedule_label: props.scheduleLabel,\n  lead_source: props.leadSource,\n};\n\nif (contact.phone) {\n  properties.phone = String(contact.phone).trim();\n}\nif (contact.company) {\n  properties.company = String(contact.company).trim();\n}\n\nreturn [{\n  json: {\n    ...payload,\n    hubspotUpsertBody: {\n      inputs: [{\n        idProperty: 'email',\n        id: contact.email,\n        properties,\n      }],\n    },\n  },\n}];"
      },
