{
  "name": "Hiweb — Calendario → Slack + GCal + HubSpot",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "hiweb-calendar-booked",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "b1b2c3d4-0001-4000-8000-000000000001",
      "name": "Webhook Calendario",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 0],
      "webhookId": "hiweb-calendar-booked"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst headers = item.headers ?? {};\nconst query = item.query ?? {};\nconst secret =\n  query.secret ??\n  headers['x-webhook-secret'] ??\n  headers['X-Webhook-Secret'] ??\n  '';\n\nconst expected = $env.HIWEB_WEBHOOK_SECRET;\nif (!expected || secret !== expected) {\n  throw new Error('Unauthorized: invalid webhook secret');\n}\n\nconst payload = item.body && typeof item.body === 'object' ? item.body : item;\n\nif (!payload.event || !payload.bookingId) {\n  throw new Error('Invalid payload: missing event or bookingId');\n}\n\nif (payload.event === 'calendar.booked') {\n  if (!payload.slack?.text) {\n    throw new Error('Invalid payload: missing slack.text for booked event');\n  }\n  if (!payload.calendar?.start || !payload.calendar?.end) {\n    throw new Error('Invalid payload: missing calendar.start/end for booked event');\n  }\n  if (!payload.hubspot?.contact?.email) {\n    throw new Error('Invalid payload: missing hubspot.contact.email for booked event');\n  }\n} else if (payload.event === 'calendar.cancelled') {\n  if (!payload.slack?.text) {\n    throw new Error('Invalid payload: missing slack.text for cancelled event');\n  }\n  if (!payload.calendar?.start || !payload.calendar?.end) {\n    throw new Error('Invalid payload: missing calendar.start/end for cancelled event');\n  }\n} else {\n  throw new Error(`Invalid payload: unknown event ${payload.event}`);\n}\n\nreturn [{ json: payload }];"
      },
      "id": "b1b2c3d4-0002-4000-8000-000000000002",
      "name": "Validar secreto",
      "type": "n8n-nodes-base.code",
