    {
      "parameters": {
        "jsCode": "const bookingId = $('Validar secreto').first().json.bookingId;\nconst items = $input.all();\n\nfor (const item of items) {\n  const event = item.json;\n  const haystack = `${event.summary || ''}\\n${event.description || ''}`;\n  if (haystack.includes(bookingId)) {\n    return [{ json: { eventId: event.id, summary: event.summary } }];\n  }\n}\n\nreturn [{ json: { eventId: null, skipped: true } }];"
      },
