# Webhooks n8n (solo servidor — no exponer en cliente)
# Calendario (Fase A): URL del Webhook node en n8n del VPS
# Ejemplo: https://n8n.tudominio.com/webhook/hiweb-calendar-booked
N8N_WEBHOOK_QUIZ_URL=
N8N_WEBHOOK_CALENDAR_URL=
N8N_WEBHOOK_ROI_URL=
# Mismo valor que HIWEB_WEBHOOK_SECRET en n8n (header X-Webhook-Secret)
N8N_WEBHOOK_SECRET=

# URL pública de la app
APP_URL=http://localhost:3000

# Webflow Cloud: mount path de la app (debe coincidir con next.config basePath)
# Ejemplo si la app vive en https://tudominio.webflow.io/growth-tools
NEXT_PUBLIC_BASE_PATH=

# Webflow CLI — importar Code Components (solo local, no commitear)
# Debe ser Workspace API token (Apps & Integrations → Workspace API Access),
# NO el Site token de un solo sitio. Site token: sites list OK, devlink import falla.
WEBFLOW_API_TOKEN=
